<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="InkColor">#F7F8FA</Color>
    <Color x:Key="MutedInkColor">#9EA8B7</Color>
    <Color x:Key="SubtleInkColor">#657386</Color>
    <Color x:Key="ShellColor">#111419</Color>
    <Color x:Key="PanelColor">#181D24</Color>
    <Color x:Key="PanelRaisedColor">#202630</Color>
    <Color x:Key="StrokeColor">#303846</Color>
    <Color x:Key="AccentColor">#59D1AC</Color>
    <Color x:Key="AccentBlueColor">#60A5FA</Color>
    <Color x:Key="WarningColor">#FFB74D</Color>

    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="MutedInkBrush" Color="{StaticResource MutedInkColor}" />
    <SolidColorBrush x:Key="SubtleInkBrush" Color="{StaticResource SubtleInkColor}" />
    <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource ShellColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelRaisedBrush" Color="{StaticResource PanelRaisedColor}" />
    <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource StrokeColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
</ResourceDictionary>

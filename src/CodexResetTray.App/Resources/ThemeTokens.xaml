<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================ -->
    <!--  PALETTE  (shared design brief — single source of truth)     -->
    <!-- ============================================================ -->

    <!-- Surfaces -->
    <Color x:Key="ShellColor">#0D1117</Color>
    <Color x:Key="PanelColor">#161B22</Color>
    <Color x:Key="PanelRaisedColor">#1C2230</Color>
    <Color x:Key="StrokeColor">#2A323C</Color>
    <Color x:Key="HairlineColor">#222A33</Color>

    <!-- Text -->
    <Color x:Key="InkColor">#E8EDF2</Color>
    <Color x:Key="MutedInkColor">#97A2AE</Color>
    <Color x:Key="SubtleInkColor">#6B7580</Color>

    <!-- 5-hour identity (emerald) -->
    <Color x:Key="AccentColor">#36D399</Color>
    <Color x:Key="AccentHoverColor">#5EE3B0</Color>

    <!-- Weekly identity (blue) -->
    <Color x:Key="AccentBlueColor">#5BA8FA</Color>
    <Color x:Key="AccentBlueHoverColor">#84C0FF</Color>

    <!-- Status ramp accents -->
    <Color x:Key="WarningColor">#F2B84B</Color>
    <Color x:Key="DangerColor">#FF6B6B</Color>

    <!-- ============================================================ -->
    <!--  SOLID BRUSHES                                                -->
    <!-- ============================================================ -->

    <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource ShellColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelRaisedBrush" Color="{StaticResource PanelRaisedColor}" />
    <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource StrokeColor}" />
    <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource HairlineColor}" />

    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="MutedInkBrush" Color="{StaticResource MutedInkColor}" />
    <SolidColorBrush x:Key="SubtleInkBrush" Color="{StaticResource SubtleInkColor}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="{StaticResource AccentBlueHoverColor}" />

    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

    <!-- Progress troughs (quiet recessed channels behind the fill) -->
    <SolidColorBrush x:Key="TrackBrush" Color="#222A33" />

    <!-- Tinted wash behind the two hero windows -->
    <SolidColorBrush x:Key="AccentWashBrush" Color="#14211C" />
    <SolidColorBrush x:Key="AccentBlueWashBrush" Color="#121C2B" />

    <!-- Warning surface (inline error) -->
    <SolidColorBrush x:Key="WarningSurfaceBrush" Color="#231C10" />
    <SolidColorBrush x:Key="WarningStrokeBrush" Color="#5A4413" />

    <!-- ============================================================ -->
    <!--  GRADIENTS                                                    -->
    <!-- ============================================================ -->

    <!-- App shell: a barely-there vertical lift so the canvas is not flat. -->
    <LinearGradientBrush x:Key="ShellGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0E141C" Offset="0" />
        <GradientStop Color="#0D1117" Offset="0.55" />
        <GradientStop Color="#0B0F14" Offset="1" />
    </LinearGradientBrush>

    <!-- Hero card: subtle top-lit surface that reads as the primary signal. -->
    <LinearGradientBrush x:Key="HeroPanelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A212B" Offset="0" />
        <GradientStop Color="#161B22" Offset="1" />
    </LinearGradientBrush>

    <!-- Header / footer chrome bars. -->
    <SolidColorBrush x:Key="ChromeBrush" Color="#10151C" />

    <!-- ============================================================ -->
    <!--  EFFECTS                                                      -->
    <!-- ============================================================ -->

    <!-- Soft, low-opacity lift reserved for the hero card only. -->
    <DropShadowEffect x:Key="HeroShadowEffect"
                      BlurRadius="28"
                      ShadowDepth="6"
                      Direction="270"
                      Opacity="0.28"
                      Color="#05070A" />

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================ -->
    <!--  "PREMIUM DARK INSTRUMENT" DESIGN SYSTEM                          -->
    <!--  Deep near-black canvas, gradient-mesh glow, vivid state ramp.    -->
    <!-- ================================================================ -->

    <!-- Fonts -->
    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="TextFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Segoe UI</FontFamily>

    <!-- Core palette -->
    <Color x:Key="ShellColor">#070A0F</Color>
    <Color x:Key="InkColor">#F5F8FB</Color>
    <Color x:Key="MutedInkColor">#9AA7B6</Color>
    <Color x:Key="SubtleInkColor">#728094</Color>
    <Color x:Key="AccentColor">#34D399</Color>

    <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource ShellColor}" />
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="MutedInkBrush" Color="{StaticResource MutedInkColor}" />
    <SolidColorBrush x:Key="SubtleInkBrush" Color="{StaticResource SubtleInkColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

    <!-- Window shell: layered vertical gradient under the gradient-mesh glows. -->
    <LinearGradientBrush x:Key="ShellGradientBrush" StartPoint="0,0" EndPoint="0.35,1">
        <GradientStop Color="#0B1016" Offset="0" />
        <GradientStop Color="#080B11" Offset="0.5" />
        <GradientStop Color="#05070B" Offset="1" />
    </LinearGradientBrush>

    <!-- Gradient-mesh glows (atmosphere/depth) painted as soft radial blooms. -->
    <RadialGradientBrush x:Key="EmeraldGlowBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#3934D399" Offset="0" />
        <GradientStop Color="#0034D399" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="VioletGlowBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#33818CF8" Offset="0" />
        <GradientStop Color="#00818CF8" Offset="1" />
    </RadialGradientBrush>

    <!-- Glass surfaces -->
    <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#16131B26" Offset="0" />
        <GradientStop Color="#0D0E1620" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="RaisedCardBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#221A2334" Offset="0" />
        <GradientStop Color="#14121A28" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#12FFFFFF" />
    <SolidColorBrush x:Key="GlassHighlightBrush" Color="#22FFFFFF" />

    <!-- Pills / chips -->
    <SolidColorBrush x:Key="PillBrush" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="PillStrokeBrush" Color="#1FFFFFFF" />

    <!-- Gauge track -->
    <SolidColorBrush x:Key="GaugeTrackBrush" Color="#16202C" />

    <!-- Accent action gradient (emerald -> cyan) -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#34D399" Offset="0" />
        <GradientStop Color="#22D3EE" Offset="1" />
    </LinearGradientBrush>
    <Color x:Key="AccentGlowColor">#34D399</Color>

    <!-- Status / warning -->
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="WarningSurfaceBrush" Color="#1F1B0E" />
    <SolidColorBrush x:Key="WarningStrokeBrush" Color="#4D3A12" />

    <!-- Window controls -->
    <SolidColorBrush x:Key="ChromeHoverBrush" Color="#18FFFFFF" />
    <SolidColorBrush x:Key="CloseHoverBrush" Color="#E81123" />

    <!-- Effects -->
    <DropShadowEffect x:Key="WindowShadowEffect" BlurRadius="34" ShadowDepth="0" Opacity="0.6" Color="#000000" />
    <DropShadowEffect x:Key="CardShadowEffect" BlurRadius="20" ShadowDepth="6" Direction="270" Opacity="0.4" Color="#04060A" />

</ResourceDictionary>

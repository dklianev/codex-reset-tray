<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="{x:Type Window}">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
        <Setter Property="Background" Value="{StaticResource ShellBrush}" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="EyebrowText" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource CopperBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="TinyText" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource SubtleInkBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="MetricNumberText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="44" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="46" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="PillBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="9,5" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="#0B0D10" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#82EBC7" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="#1E231F" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2B332D" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Height" Value="9" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="#2A302B" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid ClipToBounds="True">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" />
                        <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                            <Border Background="{TemplateBinding Foreground}" CornerRadius="4" />
                        </Decorator>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

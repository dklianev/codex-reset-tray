<Window x:Class="CodexResetTray.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CodexResetTray.App.ViewModels"
        mc:Ignorable="d"
        Title="Codex Reset Tray"
        Width="500"
        Height="660"
        MinWidth="450"
        MinHeight="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="ErrorTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MutedText}">
            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ErrorText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="Margin" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate DataType="{x:Type vm:BucketViewModel}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10" Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{Binding StateBrush}" CornerRadius="8,0,0,8" />

                    <Grid Grid.Column="1" Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding PlanLabel}" Style="{StaticResource TinyText}" Margin="0,2,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}" Padding="8,4">
                                <TextBlock Text="{Binding StateLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding StateBrush}" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="{Binding Primary.Label}" Style="{StaticResource TinyText}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Primary.UsedText}" DockPanel.Dock="Right" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="12" />
                                </DockPanel>
                                <ProgressBar Value="{Binding Primary.UsedPercent, Mode=OneWay}" Maximum="100" Margin="0,7,0,0" />
                                <TextBlock Text="{Binding Primary.ResetsText}" Style="{StaticResource MutedText}" Margin="0,7,0,0" />
                                <TextBlock Text="{Binding Primary.ExactText}" Style="{StaticResource TinyText}" Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <DockPanel>
                                    <TextBlock Text="{Binding Secondary.Label}" Style="{StaticResource TinyText}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Secondary.UsedText}" DockPanel.Dock="Right" Foreground="{StaticResource AccentBlueBrush}" FontWeight="SemiBold" FontSize="12" />
                                </DockPanel>
                                <ProgressBar Value="{Binding Secondary.UsedPercent, Mode=OneWay}" Maximum="100" Margin="0,7,0,0" Foreground="{StaticResource AccentBlueBrush}" />
                                <TextBlock Text="{Binding Secondary.ResetsText}" Style="{StaticResource MutedText}" Margin="0,7,0,0" />
                                <TextBlock Text="{Binding Secondary.ExactText}" Style="{StaticResource TinyText}" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource ShellGradientBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22,17,22,13" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Background="#0D100E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Codex Reset Tray" FontSize="23" FontWeight="Bold" />
                    <TextBlock Text="{Binding TrayStatusText}" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" Margin="0,0,7,0" />
                        <TextBlock Text="{Binding StatusTitle}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22,18,22,12">
                <Border Style="{StaticResource CardBorderStyle}"
                        Background="{StaticResource HeroPanelBrush}"
                        Padding="0"
                        Effect="{StaticResource PanelShadowEffect}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Background="{StaticResource AccentRailBrush}" CornerRadius="8,8,0,0" />

                        <Grid Grid.Row="1" Margin="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Limit Signal" Style="{StaticResource EyebrowText}" />
                                    <TextBlock Text="{Binding MainLimitName}" FontSize="30" FontWeight="Bold" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding SignalCaption}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="90" Height="78" Background="#101410" BorderBrush="{StaticResource DeepLineBrush}" BorderThickness="1" CornerRadius="8">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding HeroPercent, StringFormat={}{0}%}" FontSize="27" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="Peak load" Style="{StaticResource TinyText}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="5-hour window" Style="{StaticResource EyebrowText}" />
                                    <DockPanel Margin="0,5,0,0">
                                        <TextBlock Text="{Binding PrimaryUsageText}" Style="{StaticResource MetricNumberText}" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="used" DockPanel.Dock="Right" VerticalAlignment="Bottom" Style="{StaticResource MutedText}" Margin="8,0,0,7" />
                                    </DockPanel>
                                    <ProgressBar Value="{Binding PrimaryPercent, Mode=OneWay}" Maximum="100" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding PrimaryResetText}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding PrimaryExactText}" Style="{StaticResource TinyText}" Margin="0,2,0,0" />
                                </StackPanel>

                                <Border Grid.Column="1" Background="{StaticResource DeepLineBrush}" />

                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Weekly window" Style="{StaticResource EyebrowText}" Foreground="{StaticResource AccentBlueBrush}" />
                                    <DockPanel Margin="0,5,0,0">
                                        <TextBlock Text="{Binding WeeklyUsageText}" Style="{StaticResource MetricNumberText}" Foreground="{StaticResource AccentBlueBrush}" />
                                        <TextBlock Text="used" DockPanel.Dock="Right" VerticalAlignment="Bottom" Style="{StaticResource MutedText}" Margin="8,0,0,7" />
                                    </DockPanel>
                                    <ProgressBar Value="{Binding WeeklyPercent, Mode=OneWay}" Maximum="100" Margin="0,8,0,0" Foreground="{StaticResource AccentBlueBrush}" />
                                    <TextBlock Text="{Binding WeeklyResetText}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding WeeklyExactText}" Style="{StaticResource TinyText}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="4" Text="{Binding StatusDetail}" Style="{StaticResource MutedText}" />
                        </Grid>
                    </Grid>
                </Border>

                <Grid Margin="0,13,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PillBorderStyle}">
                        <TextBlock Text="{Binding ResetCreditsText}" FontWeight="SemiBold" FontSize="12" />
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource PillBorderStyle}">
                        <TextBlock Text="{Binding LastUpdatedText}" Style="{StaticResource TinyText}" />
                    </Border>
                </Grid>

                <TextBlock Text="{Binding ErrorText}" Style="{StaticResource ErrorTextStyle}" />
                <TextBlock Text="Bucket Details" Style="{StaticResource EyebrowText}" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding Buckets}" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="22,13,22,16" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,1,0,0" Background="#0D100E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Read-only app-server source. No auth.json reads." Style="{StaticResource TinyText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Content="Docs" Command="{Binding OpenCodexDocsCommand}" Style="{StaticResource SecondaryButton}" />
                <Button Grid.Column="3" Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" />
                <Button Grid.Column="5" Content="Exit" Command="{Binding ExitCommand}" Style="{StaticResource SecondaryButton}" />
            </Grid>
        </Border>
    </Grid>
</Window>

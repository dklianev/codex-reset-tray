<Window x:Class="CodexResetTray.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CodexResetTray.App.ViewModels"
        xmlns:ctl="clr-namespace:CodexResetTray.App.Controls"
        xmlns:conv="clr-namespace:CodexResetTray.App.Converters"
        mc:Ignorable="d"
        Title="Codex Reset Tray"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="500"
        Height="800"
        MinWidth="440"
        MinHeight="640"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <conv:PercentToGaugeBrushConverter x:Key="GaugeBrush" />
        <conv:PercentToGlowColorConverter x:Key="GlowColor" />

        <Style x:Key="ErrorSurfaceStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource WarningSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WarningStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="13,11" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ErrorText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ============= MODEL ROW ============= -->
        <DataTemplate DataType="{x:Type vm:BucketViewModel}">
            <Border Background="{StaticResource RaisedCardBrush}" BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1" CornerRadius="13" Padding="15,13" Margin="0,0,0,9">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" Style="{StaticResource TitleText}" />
                            <TextBlock Text="{Binding PlanLabel}" Style="{StaticResource CaptionText}" Margin="0,1,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center" Fill="{Binding StateBrush}" Margin="0,0,7,0" />
                            <TextBlock Text="{Binding StateLabel}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding StateBrush}" Typography.Capitals="AllSmallCaps" TextWrapping="NoWrap" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,13,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                <TextBlock Text="{Binding Primary.Label}" Style="{StaticResource EyebrowText}" />
                                <TextBlock Text="{Binding Primary.RemainingText}" DockPanel.Dock="Right"
                                           Style="{StaticResource MonoCaption}" Foreground="{StaticResource InkBrush}" />
                            </DockPanel>
                            <ProgressBar Value="{Binding Primary.RemainingPercent, Mode=OneWay}" Maximum="100"
                                         Foreground="{Binding Primary.UsedPercent, Converter={StaticResource GaugeBrush}}" />
                            <TextBlock Text="{Binding Primary.ResetsText}" Style="{StaticResource MonoCaption}" Margin="0,7,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                <TextBlock Text="{Binding Secondary.Label}" Style="{StaticResource EyebrowText}" />
                                <TextBlock Text="{Binding Secondary.RemainingText}" DockPanel.Dock="Right"
                                           Style="{StaticResource MonoCaption}" Foreground="{StaticResource InkBrush}" />
                            </DockPanel>
                            <ProgressBar Value="{Binding Secondary.RemainingPercent, Mode=OneWay}" Maximum="100"
                                         Foreground="{Binding Secondary.UsedPercent, Converter={StaticResource GaugeBrush}}" />
                            <TextBlock Text="{Binding Secondary.ResetsText}" Style="{StaticResource MonoCaption}" Margin="0,7,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:NotificationViewModel}">
            <Border Style="{StaticResource NotificationRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="7" Height="7" Fill="{Binding AccentBrush}" Margin="0,5,0,0" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource TitleText}" FontSize="12" />
                            <Ellipse Grid.Column="1" Width="6" Height="6" Fill="{Binding AccentBrush}" Margin="8,3,0,0">
                                <Ellipse.Style>
                                    <Style TargetType="{x:Type Ellipse}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUnread}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                        <TextBlock Text="{Binding Text}" Style="{StaticResource CaptionText}" Foreground="{StaticResource MutedInkBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding TimestampText}" Style="{StaticResource MonoCaption}" Margin="0,7,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer margin leaves room for the floating window shadow. -->
    <Border Margin="18" CornerRadius="18" Background="{StaticResource ShellGradientBrush}"
            BorderBrush="{StaticResource CardStrokeBrush}" BorderThickness="1"
            Effect="{StaticResource WindowShadowEffect}">
        <Grid>
            <!-- Gradient-mesh atmosphere; clip tracks window size in code-behind. -->
            <Grid x:Name="MeshLayer">
                <Ellipse Width="540" Height="540" HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-200,-220,0,0" Fill="{StaticResource EmeraldGlowBrush}" IsHitTestVisible="False" />
                <Ellipse Width="600" Height="600" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-240,-260" Fill="{StaticResource VioletGlowBrush}" IsHitTestVisible="False" />
            </Grid>

            <Grid x:Name="ContentRoot">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ContentShift" Y="0" />
                </Grid.RenderTransform>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ContentRoot" Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.45" />
                                <DoubleAnimation Storyboard.TargetName="ContentShift" Storyboard.TargetProperty="Y"
                                                 From="14" To="0" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ===== TITLE BAR ===== -->
                <Grid x:Name="TitleBar" Background="Transparent" Margin="20,16,14,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Image Source="pack://application:,,,/Assets/app.ico" Width="22" Height="22"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Grid.Column="1" Text="Codex Reset Tray" VerticalAlignment="Center" Margin="11,0,0,0"
                               FontSize="14" FontWeight="SemiBold" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Ellipse Width="9" Height="9" VerticalAlignment="Center" Fill="{Binding StatusBrush}" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="11" Opacity="0.95" Color="{Binding HeroPercent, Converter={StaticResource GlowColor}}" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusTitle}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedInkBrush}" TextWrapping="NoWrap" />
                    </StackPanel>
                    <Button Grid.Column="3" Command="{Binding ToggleNotificationsCommand}" Style="{StaticResource ChromeIconButton}"
                            VerticalAlignment="Center" ToolTip="Notifications">
                        <Grid Width="20" Height="20">
                            <Path Width="15" Height="15" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  StrokeThickness="1.45" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Data="M9,2.5 C6.6,2.5 5.2,4.2 5.2,6.7 L5.2,10.8 L3.6,13.8 L14.4,13.8 L12.8,10.8 L12.8,6.7 C12.8,4.2 11.4,2.5 9,2.5 Z M7.3,15 C7.9,16.1 10.1,16.1 10.7,15" />
                            <Border Style="{StaticResource UnreadBadgeStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-5,-7,0">
                                <TextBlock Text="{Binding UnreadNotificationCountText}" FontSize="9" FontWeight="Bold"
                                           Foreground="#07110F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Button>
                    <Button Grid.Column="4" x:Name="CloseButton" Style="{StaticResource ChromeCloseButton}"
                            VerticalAlignment="Center" Click="CloseButton_Click" />
                </Grid>

                <!-- ===== CONTENT ===== -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0" Margin="0,8,0,0">
                    <StackPanel Margin="20,8,20,8">

                        <!-- Hero: limit identity + twin gauges -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,4,0,2">
                            <TextBlock Text="{Binding MainLimitName}" FontFamily="{StaticResource DisplayFont}"
                                       FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="NoWrap" />
                            <TextBlock Text="{Binding SignalCaption}" Style="{StaticResource MonoCaption}"
                                       HorizontalAlignment="Center" Foreground="{StaticResource MutedInkBrush}" Margin="0,3,0,0" />
                        </StackPanel>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 5-hour gauge -->
                            <StackPanel Grid.Column="0">
                                <Grid Width="176" Height="150">
                                    <ctl:Gauge Percent="{Binding PrimaryRemainingPercent}" Thickness="15"
                                               TrackBrush="{StaticResource GaugeTrackBrush}"
                                               ProgressBrush="{Binding PrimaryUsedPercent, Converter={StaticResource GaugeBrush}}">
                                        <ctl:Gauge.Effect>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="22" Opacity="0.55"
                                                              Color="{Binding PrimaryUsedPercent, Converter={StaticResource GlowColor}}" />
                                        </ctl:Gauge.Effect>
                                    </ctl:Gauge>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding PrimaryRemainingValueText}" FontFamily="{StaticResource DisplayFont}"
                                                   FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"
                                                   Typography.NumeralAlignment="Tabular"
                                                   Foreground="{Binding PrimaryUsedPercent, Converter={StaticResource GaugeBrush}}" />
                                        <TextBlock Text="left • 5-hour" Style="{StaticResource EyebrowText}" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource MutedInkBrush}" Margin="0,-2,0,0" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding PrimaryResetText}" Style="{StaticResource ResetValueText}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding PrimaryExactText}" Style="{StaticResource MonoCaption}"
                                           HorizontalAlignment="Center" Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- weekly gauge -->
                            <StackPanel Grid.Column="1">
                                <Grid Width="176" Height="150">
                                    <ctl:Gauge Percent="{Binding WeeklyRemainingPercent}" Thickness="15"
                                               TrackBrush="{StaticResource GaugeTrackBrush}"
                                               ProgressBrush="{Binding WeeklyUsedPercent, Converter={StaticResource GaugeBrush}}">
                                        <ctl:Gauge.Effect>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="22" Opacity="0.55"
                                                              Color="{Binding WeeklyUsedPercent, Converter={StaticResource GlowColor}}" />
                                        </ctl:Gauge.Effect>
                                    </ctl:Gauge>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding WeeklyRemainingValueText}" FontFamily="{StaticResource DisplayFont}"
                                                   FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"
                                                   Typography.NumeralAlignment="Tabular"
                                                   Foreground="{Binding WeeklyUsedPercent, Converter={StaticResource GaugeBrush}}" />
                                        <TextBlock Text="left • weekly" Style="{StaticResource EyebrowText}" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource MutedInkBrush}" Margin="0,-2,0,0" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding WeeklyResetText}" Style="{StaticResource ResetValueText}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding WeeklyExactText}" Style="{StaticResource MonoCaption}"
                                           HorizontalAlignment="Center" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- Telemetry readout: compact status lines that stay readable in the tray-sized window. -->
                        <StackPanel Margin="0,20,0,18">
                            <Grid Margin="2,0,2,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ResetCreditsText}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource MutedInkBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding LastUpdatedText}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource SubtleInkBrush}" VerticalAlignment="Center"
                                           TextWrapping="NoWrap" Margin="14,0,0,0" />
                            </Grid>

                            <Border Background="{StaticResource PillBrush}" BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1" CornerRadius="13" Padding="13">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ResetCreditExpiryText}" Style="{StaticResource TitleText}" FontSize="12" />
                                        <TextBlock Text="{Binding ResetCreditExpiryDetailText}" Style="{StaticResource CaptionText}"
                                                   Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        <DockPanel Margin="0,10,0,0" LastChildFill="False">
                                            <TextBlock Text="{Binding AutoRefreshText}" Style="{StaticResource MonoCaption}"
                                                       DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding ResetCreditExpiryLookupText}" Style="{StaticResource MonoCaption}"
                                                       DockPanel.Dock="Right" Foreground="{StaticResource MutedInkBrush}" />
                                        </DockPanel>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Content="Opt-in" IsChecked="{Binding ResetCreditExpiryLookupEnabled, Mode=TwoWay}"
                                              Style="{StaticResource InlineToggleCheckBox}" VerticalAlignment="Top" Margin="14,1,0,0"
                                              ToolTip="Enable reset-credit expiry lookup" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Error -->
                        <Border Style="{StaticResource ErrorSurfaceStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" VerticalAlignment="Top" Margin="0,5,0,0" Fill="{StaticResource WarningBrush}" />
                                <TextBlock Grid.Column="2" Text="{Binding ErrorText}" Foreground="{StaticResource WarningBrush}" FontSize="12" TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <!-- Models -->
                        <TextBlock Text="Models" Style="{StaticResource SectionLabel}" Margin="2,0,0,11" />
                        <ItemsControl ItemsSource="{Binding Buckets}" />
                    </StackPanel>
                </ScrollViewer>

                <!-- ===== FOOTER ===== -->
                <Border Grid.Row="2" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="20,14,20,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Read-only • auth only for opt-in expiry" Style="{StaticResource MonoCaption}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Exit" Command="{Binding ExitCommand}" Style="{StaticResource SecondaryButton}" />
                        <Button Grid.Column="3" Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Panel.ZIndex="20" Style="{StaticResource NotificationPanelStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="320" MaxHeight="420" Margin="0,58,26,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Notifications" Style="{StaticResource TitleText}" />
                            <TextBlock Text="{Binding LowRemainingAlertThresholdText}" Style="{StaticResource MonoCaption}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding MarkNotificationsReadCommand}" Style="{StaticResource ChromeIconButton}"
                                ToolTip="Mark read">
                            <Path Width="14" Height="14" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Data="M1.5,7.5 L5.8,11.8 L13,2.8" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource PillBrush}" BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,8">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNotifications}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="Quiet right now" Style="{StaticResource TitleText}" FontSize="12" />
                            <TextBlock Text="Low-capacity and reset events will land here."
                                       Style="{StaticResource CaptionText}" Foreground="{StaticResource MutedInkBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="330">
                        <ItemsControl ItemsSource="{Binding Notifications}" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

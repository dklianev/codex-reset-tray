<Window x:Class="CodexResetTray.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CodexResetTray.App.ViewModels"
        mc:Ignorable="d"
        Title="Codex Reset Tray"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="500"
        Height="660"
        MinWidth="460"
        MinHeight="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>

        <!-- Inline warning surface: amber tone, collapses when ErrorText is empty. -->
        <Style x:Key="ErrorSurfaceStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource WarningSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WarningStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ErrorText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!--  BUCKET CARD                                                  -->
        <!-- ============================================================ -->
        <DataTemplate DataType="{x:Type vm:BucketViewModel}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                <StackPanel>

                    <!-- Header row: name + plan, state chip on the right. -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" Style="{StaticResource TitleText}" />
                            <TextBlock Text="{Binding PlanLabel}" Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                VerticalAlignment="Center"
                                Background="{StaticResource PanelRaisedBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="9,4">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                         Fill="{Binding StateBrush}" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding StateLabel}"
                                           FontSize="11" FontWeight="SemiBold"
                                           TextWrapping="NoWrap"
                                           Foreground="{Binding StateBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,14,0,14" />

                    <!-- Two windows side by side. -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Primary (5-hour) -->
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding Primary.Label}" Style="{StaticResource EyebrowText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Primary.UsedText}" DockPanel.Dock="Right"
                                           Foreground="{StaticResource InkBrush}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Typography.NumeralAlignment="Tabular" />
                            </DockPanel>
                            <ProgressBar Value="{Binding Primary.UsedPercent, Mode=OneWay}" Maximum="100"
                                         Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding Primary.ResetsText}" Style="{StaticResource MutedText}"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding Primary.ExactText}" Style="{StaticResource CaptionText}"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Secondary (weekly) -->
                        <StackPanel Grid.Column="2">
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding Secondary.Label}" Style="{StaticResource EyebrowText}"
                                           Foreground="{StaticResource AccentBlueBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Secondary.UsedText}" DockPanel.Dock="Right"
                                           Foreground="{StaticResource InkBrush}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Typography.NumeralAlignment="Tabular" />
                            </DockPanel>
                            <ProgressBar Value="{Binding Secondary.UsedPercent, Mode=OneWay}" Maximum="100"
                                         Foreground="{StaticResource AccentBlueBrush}" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding Secondary.ResetsText}" Style="{StaticResource MutedText}"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding Secondary.ExactText}" Style="{StaticResource CaptionText}"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- ================================================================ -->
    <!--  THREE-ZONE SHELL: header / scrollable content / footer          -->
    <!-- ================================================================ -->
    <Grid Background="{StaticResource ShellGradientBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16,20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Codex Reset Tray" FontSize="16" FontWeight="SemiBold"
                               TextWrapping="NoWrap" />
                    <TextBlock Text="Rate-limit windows" Style="{StaticResource CaptionText}"
                               Margin="0,2,0,0" TextWrapping="NoWrap" />
                </StackPanel>

                <!-- Status chip: colored dot (StatusBrush) + StatusTitle. -->
                <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                 Fill="{Binding StatusBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding StatusTitle}" FontSize="12" FontWeight="SemiBold"
                                   TextWrapping="NoWrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== SCROLLABLE CONTENT ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Margin="20,20,20,16">

                <!-- ===== HERO CARD ===== -->
                <Border Style="{StaticResource CardBorderStyle}"
                        Background="{StaticResource HeroPanelBrush}"
                        Padding="20"
                        Effect="{StaticResource HeroShadowEffect}">
                    <StackPanel>

                        <!-- Hero header: limit identity + the single peak-load signal. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Limit signal" Style="{StaticResource EyebrowText}" />
                                <TextBlock Text="{Binding MainLimitName}" FontSize="22" FontWeight="Bold"
                                           Margin="0,4,0,0" TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding SignalCaption}" Style="{StaticResource MutedText}"
                                           Margin="0,5,0,0" TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right"
                                        Margin="16,0,0,0">
                                <TextBlock Text="{Binding HeroPercent, StringFormat={}{0}%}"
                                           Style="{StaticResource HeroNumberText}"
                                           Foreground="{Binding StatusBrush}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="peak load" Style="{StaticResource CaptionText}"
                                           HorizontalAlignment="Right" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- Two windows as raised insets. -->
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 5-hour (emerald) -->
                            <Border Style="{StaticResource InsetBorderStyle}" Background="{StaticResource AccentWashBrush}">
                                <StackPanel>
                                    <TextBlock Text="5-hour window" Style="{StaticResource EyebrowText}"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                        <TextBlock Text="{Binding PrimaryUsageText}" Style="{StaticResource WindowNumberText}"
                                                   Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="used" DockPanel.Dock="Right" VerticalAlignment="Bottom"
                                                   Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                                    </DockPanel>
                                    <ProgressBar Value="{Binding PrimaryPercent, Mode=OneWay}" Maximum="100"
                                                 Foreground="{StaticResource AccentBrush}" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding PrimaryResetText}" Style="{StaticResource ResetValueText}"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="{Binding PrimaryExactText}" Style="{StaticResource CaptionText}"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Weekly (blue) -->
                            <Border Grid.Column="2" Style="{StaticResource InsetBorderStyle}" Background="{StaticResource AccentBlueWashBrush}">
                                <StackPanel>
                                    <TextBlock Text="Weekly window" Style="{StaticResource EyebrowText}"
                                               Foreground="{StaticResource AccentBlueBrush}" />
                                    <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                        <TextBlock Text="{Binding WeeklyUsageText}" Style="{StaticResource WindowNumberText}"
                                                   Foreground="{StaticResource AccentBlueBrush}" />
                                        <TextBlock Text="used" DockPanel.Dock="Right" VerticalAlignment="Bottom"
                                                   Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                                    </DockPanel>
                                    <ProgressBar Value="{Binding WeeklyPercent, Mode=OneWay}" Maximum="100"
                                                 Foreground="{StaticResource AccentBlueBrush}" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding WeeklyResetText}" Style="{StaticResource ResetValueText}"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="{Binding WeeklyExactText}" Style="{StaticResource CaptionText}"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Quiet supporting detail line. -->
                        <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,16,0,14" />
                        <TextBlock Text="{Binding StatusDetail}" Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>

                <!-- ===== META ROW ===== -->
                <Grid Margin="0,14,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PillBorderStyle}">
                        <TextBlock Text="{Binding ResetCreditsText}" FontSize="12" FontWeight="SemiBold"
                                   TextWrapping="NoWrap" Typography.NumeralAlignment="Tabular" />
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource PillBorderStyle}">
                        <TextBlock Text="{Binding LastUpdatedText}" Style="{StaticResource CaptionText}"
                                   TextWrapping="NoWrap" Typography.NumeralAlignment="Tabular" />
                    </Border>
                </Grid>

                <!-- ===== INLINE WARNING ===== -->
                <Border Style="{StaticResource ErrorSurfaceStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="8" Height="8" VerticalAlignment="Top" Margin="0,5,0,0"
                                 Fill="{StaticResource WarningBrush}" />
                        <TextBlock Grid.Column="2" Text="{Binding ErrorText}"
                                   Foreground="{StaticResource WarningBrush}" FontSize="12" />
                    </Grid>
                </Border>

                <!-- ===== BUCKET DETAILS ===== -->
                <TextBlock Text="Bucket details" Style="{StaticResource SectionHeadingText}" Margin="2,0,0,10" />
                <ItemsControl ItemsSource="{Binding Buckets}" />
            </StackPanel>
        </ScrollViewer>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="2" Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,14,20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Read-only app-server source"
                           Style="{StaticResource CaptionText}" VerticalAlignment="Center"
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Content="Docs" Command="{Binding OpenCodexDocsCommand}"
                        Style="{StaticResource SecondaryButton}" />
                <Button Grid.Column="3" Content="Exit" Command="{Binding ExitCommand}"
                        Style="{StaticResource SecondaryButton}" />
                <Button Grid.Column="5" Content="Refresh" Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButton}" />
            </Grid>
        </Border>
    </Grid>
</Window>
